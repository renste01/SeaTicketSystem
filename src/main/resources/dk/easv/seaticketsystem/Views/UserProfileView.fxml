<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.seaticketsystem.GUI.Controllers.UserProfileViewController"
            fitToWidth="true"
            styleClass="page-scroll">

    <VBox spacing="24">
        <padding>
            <Insets top="28" right="28" bottom="28" left="28"/>
        </padding>

        <!-- Back button -->
        <Button text="← Tilbage til søgning"
                onAction="#handleBack"
                styleClass="btn-secondary"/>

        <!-- Profile header card -->
        <VBox styleClass="profile-header-box" spacing="12" alignment="CENTER">
            <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

            <!-- Avatar circle -->
            <StackPane>
                <javafx.scene.shape.Circle radius="44" styleClass="avatar-circle"/>
                <Label fx:id="initialsLabel" styleClass="avatar-initials"/>
            </StackPane>

            <Label fx:id="nameLabel" styleClass="profile-name"/>
            <Label fx:id="roleLabel" styleClass="profile-role"/>
        </VBox>

        <!-- Details card -->
        <VBox styleClass="admin-section-card" spacing="16">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <Label text="PERSONLIGE OPLYSNINGER" styleClass="sidebar-section-label"/>

            <GridPane hgap="16" vgap="14">
                <columnConstraints>
                    <ColumnConstraints prefWidth="160"/>
                    <ColumnConstraints prefWidth="300"/>
                </columnConstraints>

                <Label text="Fornavn:" styleClass="detail-key"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="firstNameLabel" styleClass="detail-value"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Efternavn:" styleClass="detail-key"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lastNameLabel" styleClass="detail-value"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="E-mail:" styleClass="detail-key"
                       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="emailLabel" styleClass="detail-value"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Rolle:" styleClass="detail-key"
                       GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="roleLabel" styleClass="detail-value"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>

    </VBox>
</ScrollPane>