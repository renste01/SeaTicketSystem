<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.seaticketsystem.GUI.Controllers.UserSearchController"
            fitToWidth="true"
            styleClass="page-scroll">

    <VBox spacing="20">
        <padding>
            <Insets top="28" right="28" bottom="28" left="28"/>
        </padding>

        <Label text="Søg efter bruger" styleClass="page-title"/>
        <Label text="Søg på navn eller email for at finde en bruger."
               styleClass="admin-welcome-sub"/>

        <!-- Search bar -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField"
                       promptText="🔍  Søg på navn eller email..."
                       prefWidth="400"
                       styleClass="form-field"/>
        </HBox>

        <!-- No results label -->
        <Label fx:id="noResultsLabel"
               text="Ingen brugere fundet."
               styleClass="error-label"
               visible="false"
               managed="false"/>

        <!-- Results -->
        <TilePane fx:id="resultsContainer"
                  hgap="14"
                  vgap="14"
                  prefColumns="2"
                  alignment="TOP_LEFT"/>

    </VBox>
</ScrollPane>
