<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.seaticketsystem.GUI.Controllers.AdminUserController"
      spacing="12" padding="20">

    <Label text="Brugeradministration" styleClass="page-title"/>

    <TableView fx:id="userTable" prefHeight="400">
        <columns>
            <TableColumn fx:id="colName" text="Navn" prefWidth="200"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
            <TableColumn fx:id="colRole" text="Rolle" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="➕ Opret bruger" onAction="#handleOpenCreateUser"/>
        <Button text="🗑 Slet valgt" onAction="#handleDeleteUser"/>
    </HBox>

</VBox>