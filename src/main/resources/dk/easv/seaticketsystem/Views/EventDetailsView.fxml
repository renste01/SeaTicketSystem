<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.seaticketsystem.GUI.Controllers.EventDetailsController"
      spacing="16">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Event Detaljer" styleClass="page-title"/>

    <VBox spacing="8">
        <Label text="Titel:" styleClass="detail-key"/>
        <Label fx:id="titleLabel" styleClass="detail-value"/>

        <Label text="Dato:" styleClass="detail-key"/>
        <Label fx:id="dateLabel" styleClass="detail-value"/>

        <Label text="Starttid:" styleClass="detail-key"/>
        <Label fx:id="startTimeLabel" styleClass="detail-value"/>

        <Label text="Sluttid:" styleClass="detail-key"/>
        <Label fx:id="endTimeLabel" styleClass="detail-value"/>

        <Label text="Sted:" styleClass="detail-key"/>
        <Label fx:id="locationLabel" styleClass="detail-value"/>

        <Label text="Lokationsvejledning:" styleClass="detail-key"/>
        <Label fx:id="locationGuidanceLabel" styleClass="detail-value"/>

        <Label text="Beskrivelse:" styleClass="detail-key"/>
        <TextArea fx:id="descriptionArea"
                  editable="false"
                  wrapText="true"
                  prefRowCount="6"/>
    </VBox>

    <Button fx:id="editButton"
            text="✏️ Rediger Event"
            onAction="#handleEdit"
            styleClass="btn-primary"/>

    <!-- Ticket Table -->
    <TableView fx:id="ticketTable" prefHeight="200">
        <columns>
            <TableColumn text="Ticket ID" fx:id="colTicketId" prefWidth="200"/>
            <TableColumn text="Price" fx:id="colPrice" prefWidth="100"/>
        </columns>
    </TableView>

    <!-- Ticket Creation -->
    <HBox spacing="10">
        <TextField fx:id="priceField" promptText="Ticket price" prefWidth="150"/>
        <Button text="➕ Opret Ticket" onAction="#handleCreateTicket"/>
    </HBox>

</VBox>
