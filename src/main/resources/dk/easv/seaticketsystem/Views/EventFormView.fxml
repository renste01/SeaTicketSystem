<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.seaticketsystem.GUI.Controllers.EventFormController"
      spacing="20">

    <padding>
        <Insets top="28" right="28" bottom="28" left="28"/>
    </padding>

    <Label fx:id="formTitleLabel" styleClass="page-title"/>

    <VBox spacing="14" styleClass="admin-section-card">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <GridPane hgap="12" vgap="14">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" prefWidth="140"/>
                <ColumnConstraints prefWidth="300"/>
            </columnConstraints>

            <Label text="Titel:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="titleField" promptText="Event titel"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Sted:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="locationField" promptText="Hvor afholdes eventet?"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Startdato:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <DatePicker fx:id="datePicker"
                        GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Starttid (HH:mm):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="startTimeField" promptText="Fx 14:00"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Slutdato:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <DatePicker fx:id="endDatePicker"
                        GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Sluttid (HH:mm):" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="endTimeField" promptText="Fx 18:00"
                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label text="Beskrivelse:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <TextArea fx:id="descriptionField"
                      promptText="Kort beskrivelse af eventet"
                      wrapText="true" prefRowCount="4"
                      GridPane.rowIndex="6" GridPane.columnIndex="1"/>

            <Label text="Vejledning til sted:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
            <TextField fx:id="locationGuidanceField" promptText="Fx 'Indgang ved havnen'"
                       GridPane.rowIndex="7" GridPane.columnIndex="1"/>

            <Label text="VIP billetter:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
            <CheckBox fx:id="vipCheckBox" text="Aktivér VIP"
                      GridPane.rowIndex="8" GridPane.columnIndex="1"/>
        </GridPane>

        <Label fx:id="errorLabel" styleClass="error-label"
               visible="false" managed="false"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="✖ Annuller" onAction="#handleCancel" styleClass="btn-secondary"/>
            <Button fx:id="saveButton" onAction="#handleSave" styleClass="btn-primary"/>
        </HBox>
    </VBox>

</VBox>