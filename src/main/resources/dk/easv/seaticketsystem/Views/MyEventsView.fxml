<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.seaticketsystem.GUI.Controllers.MyEventsController"
            fitToWidth="true"
            styleClass="page-scroll">

    <VBox spacing="14" styleClass="page-compact">
        <padding>
            <Insets top="16" right="16" bottom="16" left="16"/>
        </padding>

        <Label text="Mine Events" styleClass="page-title"/>
        <Label text="Her kan du se dine events og invitere ko-koordinatorer."
               styleClass="admin-welcome-sub"/>

        <VBox fx:id="eventCardsContainer" spacing="12"/>

    </VBox>
</ScrollPane>
