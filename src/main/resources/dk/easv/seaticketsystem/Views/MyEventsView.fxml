<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.seaticketsystem.GUI.Controllers.MyEventsController"
            fitToWidth="true"
            styleClass="page-scroll">

    <VBox spacing="24">
        <padding>
            <Insets top="28" right="28" bottom="28" left="28"/>
        </padding>

        <Label text="Mine Events" styleClass="page-title"/>
        <Label text="Her kan du se dine events og invitere ko-koordinatorer."
               styleClass="admin-welcome-sub"/>

        <VBox fx:id="eventCardsContainer" spacing="16"/>

    </VBox>
</ScrollPane>