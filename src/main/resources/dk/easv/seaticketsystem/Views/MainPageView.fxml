<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.seaticketsystem.GUI.Controllers.MainLayoutController"
            styleClass="main-root">

    <!-- ======= SIDEBAR (venstre) ======= -->
    <left>
        <VBox styleClass="sidebar" prefWidth="245" spacing="0">

            <!-- Logo sektion -->
            <VBox styleClass="sidebar-logo" alignment="CENTER_LEFT" spacing="4">
                <padding><Insets top="20" right="18" bottom="16" left="18"/></padding>
                <StackPane fx:id="sidebarLogoPane" prefHeight="22"/>
                <Label text="BILLETSYSTEM" styleClass="sidebar-logo-sub"/>
            </VBox>

            <!-- Brugerinfo -->
            <VBox styleClass="sidebar-user" alignment="CENTER_LEFT">
                <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
                <Label fx:id="userNameLabel" styleClass="sidebar-username"/>
                <Label fx:id="userRoleLabel" styleClass="sidebar-role"/>
            </VBox>

            <Separator styleClass="sidebar-separator"/>

            <!-- Fælles navigation (alle roller) -->
            <VBox styleClass="sidebar-nav" spacing="6">
                <padding><Insets top="10" right="10" bottom="0" left="10"/></padding>
                <Label text="MENU" styleClass="sidebar-section-label"/>

                <Button text="🎟" styleClass="sidebar-btn-icon" onAction="#openMyTickets">
                    <tooltip><Tooltip text="Mine Billetter"/></tooltip>
                </Button>

                <Button text="📅" styleClass="sidebar-btn-icon" onAction="#openEvents">
                    <tooltip><Tooltip text="Events"/></tooltip>
                </Button>

                <Button text="👤" styleClass="sidebar-btn-icon" onAction="#handleProfile">
                    <tooltip><Tooltip text="Min Profil"/></tooltip>
                </Button>
            </VBox>

            <!-- Søgning (kun admin og koordinator) -->
            <VBox fx:id="userMenu" styleClass="sidebar-nav" spacing="6">
                <padding><Insets top="10" right="10" bottom="0" left="10"/></padding>
                <Label text="SØGNING" styleClass="sidebar-section-label"/>

                <Button text="🔍" styleClass="sidebar-btn-icon" onAction="#openUserSearch">
                    <tooltip><Tooltip text="Søg bruger"/></tooltip>
                </Button>
            </VBox>

            <!-- Koordinator-menu -->
            <VBox fx:id="coordinatorMenu" styleClass="sidebar-nav" spacing="6">
                <padding><Insets top="10" right="10" bottom="0" left="10"/></padding>
                <Label text="KOORDINATOR" styleClass="sidebar-section-label"/>

                <Button text="📋" styleClass="sidebar-btn-icon" onAction="#openMyEvents">
                    <tooltip><Tooltip text="Mine Events"/></tooltip>
                </Button>

                <Button text="➕" styleClass="sidebar-btn-icon" onAction="#openCreateEvent">
                    <tooltip><Tooltip text="Opret Event"/></tooltip>
                </Button>

                <Button text="🎁" styleClass="sidebar-btn-icon" onAction="#openFreeTickets">
                    <tooltip><Tooltip text="Fribilletter"/></tooltip>
                </Button>
            </VBox>

            <!-- Admin-menu -->
            <VBox fx:id="adminMenu" styleClass="sidebar-nav" spacing="6">
                <padding><Insets top="10" right="10" bottom="0" left="10"/></padding>
                <Label text="ADMINISTRATOR" styleClass="sidebar-section-label"/>

                <Button text="🏠" styleClass="sidebar-btn-icon" onAction="#openDashboard">
                    <tooltip><Tooltip text="Dashboard"/></tooltip>
                </Button>

                <Button text="👥" styleClass="sidebar-btn-icon" onAction="#openUserAdmin">
                    <tooltip><Tooltip text="Administrer Brugere"/></tooltip>
                </Button>

                <Button text="📂" styleClass="sidebar-btn-icon" onAction="#openAdminEvents">
                    <tooltip><Tooltip text="Administrer Events"/></tooltip>
                </Button>
            </VBox>

            <!-- Fyld plads -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Log ud -->
            <VBox styleClass="sidebar-nav">
                <padding><Insets top="0" right="10" bottom="16" left="10"/></padding>
                <Button text="⬅" styleClass="sidebar-btn-icon" onAction="#handleLogout">
                    <tooltip><Tooltip text="Log ud"/></tooltip>
                </Button>
            </VBox>

        </VBox>
    </left>

    <!-- ======= INDHOLD (midt) ======= -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>