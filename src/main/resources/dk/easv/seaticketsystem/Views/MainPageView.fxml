<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.seaticketsystem.GUI.Controllers.MainLayoutController"
            styleClass="main-root">

    <!-- ======= SIDEBAR (venstre) ======= -->
    <left>
        <VBox styleClass="sidebar" prefWidth="245" spacing="0">

            <!-- Logo sektion -->
            <VBox styleClass="sidebar-logo" alignment="CENTER_LEFT" spacing="4">
                <padding><Insets top="20" right="18" bottom="16" left="18"/></padding>
                <StackPane fx:id="sidebarLogoPane" prefHeight="22"/>
                <Label text="BILLETSYSTEM" styleClass="sidebar-logo-sub"/>
            </VBox>

            <!-- Brugerinfo -->
            <VBox styleClass="sidebar-user" alignment="CENTER_LEFT">
                <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
                <Label fx:id="userNameLabel" styleClass="sidebar-username"/>
                <Label fx:id="userRoleLabel" styleClass="sidebar-role"/>
            </VBox>

            <Separator styleClass="sidebar-separator"/>

            <!-- Fælles navigation -->
            <VBox styleClass="sidebar-nav" spacing="2">
                <padding><Insets top="10" right="10" bottom="0" left="10"/></padding>
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🎟  Mine Billetter"
                        maxWidth="Infinity" styleClass="sidebar-btn"/>
                <Button text="📅  Events"
                        maxWidth="Infinity" styleClass="sidebar-btn"/>
                <Button text="👤  Min Profil"
                        maxWidth="Infinity" styleClass="sidebar-btn"/>
            </VBox>

            <!-- Koordinator-menu -->
            <VBox fx:id="coordinatorMenu" styleClass="sidebar-nav" spacing="2">
                <padding><Insets top="10" right="10" bottom="0" left="10"/></padding>
                <Label text="KOORDINATOR" styleClass="sidebar-section-label"/>
                <Button text="📋  Mine Events"
                        maxWidth="Infinity" styleClass="sidebar-btn"/>
                <Button text="➕  Opret Event"
                        maxWidth="Infinity" styleClass="sidebar-btn"/>
                <Button text="🎁  Fribilletter"
                        maxWidth="Infinity" styleClass="sidebar-btn"/>
            </VBox>

            <!-- Admin-menu -->
            <VBox fx:id="adminMenu" styleClass="sidebar-nav" spacing="2">
                <padding><Insets top="10" right="10" bottom="0" left="10"/></padding>
                <Label text="ADMINISTRATOR" styleClass="sidebar-section-label"/>

                <Button text="🏠  Dashboard"
                        maxWidth="Infinity" styleClass="sidebar-btn"/>

                <!-- ⭐ HER ER DEN VIGTIGE ÆNDRING ⭐ -->
                <Button text="👥  Administrer Brugere"
                        maxWidth="Infinity" styleClass="sidebar-btn"
                        onAction="#openUserAdmin"/>

                <Button text="📂  Administrer Events"
                        maxWidth="Infinity" styleClass="sidebar-btn"/>
            </VBox>

            <!-- Fyld plads -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Log ud -->
            <VBox styleClass="sidebar-nav">
                <padding><Insets top="0" right="10" bottom="16" left="10"/></padding>
                <Button text="⬅  Log ud" onAction="#handleLogout"
                        maxWidth="Infinity" styleClass="sidebar-btn sidebar-btn-logout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ======= INDHOLD (midt) ======= -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>