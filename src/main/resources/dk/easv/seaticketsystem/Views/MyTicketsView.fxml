<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.seaticketsystem.GUI.Controllers.MyTicketsController"
      spacing="12"
      styleClass="page-compact">

    <padding>
        <Insets top="14" right="16" bottom="14" left="16"/>
    </padding>

    <Label text="Billetter" styleClass="page-title"/>
    <Label text="Opret billetter her. Åbn en billet for at sende den senere." styleClass="info-label"/>

    <VBox spacing="8" styleClass="admin-section-card">
        <Label text="Registrer billetkøb" styleClass="section-title"/>

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints prefWidth="140"/>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints prefWidth="140"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Vælg event:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="eventComboBox" promptText="Vælg event"
                      GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Antal:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <TextField fx:id="ticketCountField" text="1"
                       GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="Vælg modtager:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <HBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1">
                <ComboBox fx:id="receiverUserComboBox" promptText="Vælg bruger (valgfri)" HBox.hgrow="ALWAYS"/>
                <Button text="Ryd" onAction="#handleClearReceiverSelection" styleClass="btn-compact"/>
            </HBox>

            <Label text="Pris pr. billet:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <TextField fx:id="priceField" promptText="Fx 100"
                       GridPane.rowIndex="1" GridPane.columnIndex="3"/>

            <Label text="Navn:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="customerNameField" promptText="Fx Anna Jensen"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Billet type:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
            <ComboBox fx:id="ticketTypeComboBox" promptText="Vælg type"
                       GridPane.rowIndex="2" GridPane.columnIndex="3"/>

            <Label text="E-mail:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="customerEmailField" promptText="anna@email.dk"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </GridPane>

        <HBox spacing="10">
            <Button text="Opret billetter" onAction="#handleIssueTickets" styleClass="btn-primary" prefWidth="150"/>
            <Button text="Åbn billet" onAction="#handleOpenTicket" styleClass="btn-teal"/>
            <Button text="Slet billet" onAction="#handleDeleteTicket" styleClass="btn-danger"/>
            <Label fx:id="ticketFeedbackLabel" visible="false" managed="false"/>
        </HBox>
    </VBox>

    <TableView fx:id="ticketTable" prefHeight="380" styleClass="sea-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Event" fx:id="colEvent" prefWidth="230"/>
            <TableColumn text="Kunde" fx:id="colCustomer" prefWidth="180"/>
            <TableColumn text="E-mail" fx:id="colEmail" prefWidth="220"/>
            <TableColumn text="Type" fx:id="colType" prefWidth="90"/>
            <TableColumn text="Pris" fx:id="colPrice" prefWidth="85"/>
            <TableColumn text="Status" fx:id="colStatus" prefWidth="100"/>
            <TableColumn text="Sendt" fx:id="colSentAt" prefWidth="165"/>
        </columns>
    </TableView>

    <Label text="Tip: Dobbeltklik på en billet for at åbne detaljer." styleClass="hint-text"/>

</VBox>
